// Prisma Schema for TalkZap
// Multi-tenant condominium management platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================
// Enums
// =====================================================

enum UserRole {
  SUPER_ADMIN
  PROFESSIONAL_SYNDIC
  ADMIN
  SYNDIC
  TRIAGE
  SETOR_MANAGER
  SETOR_MEMBER
  RESIDENT
}

enum PermissionScope {
  GLOBAL
  LOCAL
}

enum ComplaintStatus {
  OPEN // legado (init); tratar como TRIAGE na UI
  NEW
  TRIAGE
  IN_PROGRESS
  WAITING_USER
  WAITING_THIRD_PARTY
  RESOLVED
  CLOSED
  CANCELLED
  RETURNED
  REOPENED
}

enum ComplaintPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum DocumentStatus {
  PENDING
  VALIDATING
  APPROVED
  REJECTED
}

enum ResidentType {
  OWNER
  TENANT
}

enum CondominiumStatus {
  TRIAL
  ACTIVE
  SUSPENDED
}

enum CondominiumPermissionMode {
  ROLE_DEFAULT
  CUSTOM
}

enum MessageType {
  TEXT
  TEMPLATE
  IMAGE
}

enum MessageScope {
  ALL
  TOWER
  FLOOR
  UNIT
}

enum WhatsAppStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum UserStatus {
  PENDING // Aguardando aprovação
  APPROVED // Aprovado e pode usar o sistema
  REJECTED // Cadastro rejeitado
  SUSPENDED // Suspenso temporariamente
}

// =====================================================
// Models
// =====================================================

model Condominium {
  id        String            @id @default(cuid())
  name      String
  /// Identificador único para URLs de cadastro (ex.: /auth/register/meu-condominio)
  slug      String            @unique
  cnpj      String            @unique
  status    CondominiumStatus @default(TRIAL)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  // WhatsApp configuration
  whatsappPhone      String? @map("whatsapp_phone")
  whatsappBusinessId String? @map("whatsapp_business_id")

  // Trial management (deprecated — replaced by Subscription model; kept for backward compat until destructive migration)
  trialEndsAt DateTime? @map("trial_ends_at")

  // Billing ownership (see billing spec)
  primarySyndicId String? @map("primary_syndic_id")
  primarySyndic   User?   @relation("OwnedCondominiums", fields: [primarySyndicId], references: [id])

  // Structure configuration (JSON)
  // Formato: { "towers": [{ "name": "A", "floors": ["1", "2", "3"], "unitsPerFloor": 4 }] }
  structure Json? @db.JsonB

  // Automation flags
  autoTriageEnabled      Boolean @default(true) @map("auto_triage_enabled")
  autoAssignEnabled      Boolean @default(true) @map("auto_assign_enabled")
  autoCloseAfterDays     Int     @default(7) @map("auto_close_after_days")
  waitingAutoResolveDays Int     @default(14) @map("waiting_auto_resolve_days")
  reopenDeadlineDays     Int     @default(7) @map("reopen_deadline_days")

  // Relations
  users           UserCondominium[]
  residents       Resident[]
  complaints      Complaint[]
  messages        Message[]
  sectors         Sector[]
  slaConfigs      SlaConfig[]
  announcements   Announcement[]
  cannedResponses CannedResponse[]
  residentInvites ResidentInvite[]

  @@index([cnpj])
  @@index([primarySyndicId])
  @@map("condominiums")
}

/// Convite criado pelo síndico para o morador concluir cadastro via link (WhatsApp).
model ResidentInvite {
  id               String    @id @default(cuid())
  condominiumId    String    @map("condominium_id")
  createdByUserId  String    @map("created_by_user_id")
  name             String
  phone            String
  tower            String?
  floor            String?
  unit             String?
  tokenHash        String    @unique @map("token_hash")
  expiresAt        DateTime  @map("expires_at")
  consumedAt       DateTime? @map("consumed_at")
  consumedByUserId String?   @map("consumed_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")

  condominium Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("ResidentInviteCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([condominiumId, phone])
  @@map("resident_invites")
}

model Announcement {
  id            String       @id @default(cuid())
  condominiumId String       @map("condominium_id")
  title         String
  content       String       @db.Text
  imageUrl      String?      @map("image_url")
  startsAt      DateTime     @map("starts_at")
  endsAt        DateTime     @map("ends_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  createdBy     String?      @map("created_by")
  scope         MessageScope @default(ALL)
  targetTower   String?      @map("target_tower")
  targetFloor   String?      @map("target_floor")
  targetUnit    String?      @map("target_unit")
  sendWhatsApp  Boolean      @default(false) @map("send_whatsapp")
  expiresAt     DateTime?    @map("expires_at")

  condominium Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  author      User?       @relation("AnnouncementAuthor", fields: [createdBy], references: [id])

  @@index([condominiumId])
  @@index([condominiumId, startsAt, endsAt])
  @@map("announcements")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  password        String
  name            String
  role            UserRole        @default(RESIDENT)
  permissionScope PermissionScope @default(LOCAL) @map("permission_scope")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Approval System
  status          UserStatus @default(PENDING)
  approvedAt      DateTime?  @map("approved_at")
  approvedBy      String?    @map("approved_by")
  rejectionReason String?    @map("rejection_reason") @db.Text

  // Pending Allocation (dados informados no cadastro, antes da aprovação)
  requestedCondominiumId String? @map("requested_condominium_id")
  requestedTower         String? @map("requested_tower")
  requestedFloor         String? @map("requested_floor")
  requestedUnit          String? @map("requested_unit")
  requestedPhone         String? @map("requested_phone")

  // LGPD Consent (coletado no cadastro, transferido para Resident na aprovação)
  // Consentimento WhatsApp é OBRIGATÓRIO para se cadastrar na plataforma
  consentWhatsapp       Boolean @default(true) @map("consent_whatsapp")
  consentDataProcessing Boolean @default(true) @map("consent_data_processing")

  // MFA
  mfaEnabled Boolean @default(false) @map("mfa_enabled")
  mfaSecret  String? @map("mfa_secret")

  // Password Reset
  forcePasswordReset Boolean @default(false) @map("force_password_reset")

  // Syndic Profile (public)
  contactPhone String?
  photoUrl     String?
  officeHours  String?
  publicNotes  String? @db.Text

  // Syndic Profile (private)
  address      String?
  websiteUrl   String?
  privateNotes String? @db.Text

  // Account Expiration
  accountExpiresAt DateTime?

  // Relations
  condominiums          UserCondominium[]
  resident              Resident?
  sectorMembers         SectorMember[]
  assigneeComplaints    Complaint[]           @relation("ComplaintAssignee")
  escalatedComplaints   Complaint[]           @relation("ComplaintEscalationTarget")
  assignedComplaints    ComplaintAssignment[] @relation("ComplaintAssignmentAssignedBy")
  assignedToComplaints  ComplaintAssignment[] @relation("ComplaintAssignmentAssignee")
  notifications         Notification[]        @relation("UserNotifications")
  sentComplaintMessages ComplaintMessage[]    @relation("ComplaintMessageSender")
  createdAnnouncements  Announcement[]        @relation("AnnouncementAuthor")

  // Billing
  subscription           Subscription?    @relation("SyndicSubscription")
  ownedCondominiums      Condominium[]    @relation("OwnedCondominiums")
  createdResidentInvites ResidentInvite[] @relation("ResidentInviteCreator")

  @@index([email])
  @@index([status])
  @@index([requestedCondominiumId])
  @@map("users")
}

model UserCondominium {
  id              String                    @id @default(cuid())
  userId          String                    @map("user_id")
  condominiumId   String                    @map("condominium_id")
  role            UserRole
  councilPosition String?                   @map("council_position") // Função no condomínio (ex: Conselheiro, Porteiro, Obras)
  assignedTower   String?                   @map("assigned_tower")
  permissionMode  CondominiumPermissionMode @default(ROLE_DEFAULT) @map("permission_mode")
  createdAt       DateTime                  @default(now()) @map("created_at")

  // Relations
  user              User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  condominium       Condominium                 @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  customPermissions UserCondominiumPermission[]

  @@unique([userId, condominiumId])
  @@index([userId])
  @@index([condominiumId])
  @@map("user_condominiums")
}

model UserCondominiumPermission {
  id                String   @id @default(cuid())
  userCondominiumId String   @map("user_condominium_id")
  action            String
  createdAt         DateTime @default(now()) @map("created_at")

  userCondominium UserCondominium @relation(fields: [userCondominiumId], references: [id], onDelete: Cascade)

  @@unique([userCondominiumId, action])
  @@index([userCondominiumId])
  @@map("user_condominium_permissions")
}

model Resident {
  id            String       @id @default(cuid())
  condominiumId String       @map("condominium_id")
  userId        String?      @unique @map("user_id")
  name          String
  email         String       @default("pendente@talkzap.com")
  phone         String
  tower         String
  floor         String
  unit          String
  type          ResidentType @default(OWNER)
  createdAt     DateTime     @default(now()) @map("created_at")

  // LGPD Compliance — opt-in only. Default is FALSE so a row created
  // without an explicit consent flag never sends WhatsApp messages by
  // accident. The síndico flow must collect consent explicitly before
  // toggling this to true (tracked in register-invite/createResident).
  consentWhatsapp       Boolean @default(false) @map("consent_whatsapp")
  consentDataProcessing Boolean @default(true) @map("consent_data_processing")

  // Relations
  condominium Condominium        @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  user        User?              @relation(fields: [userId], references: [id])
  complaints  Complaint[]
  documents   ResidentDocument[]

  @@unique([condominiumId, tower, floor, unit])
  @@index([condominiumId, phone])
  @@index([condominiumId, email])
  @@map("residents")
}

model Complaint {
  id                 Int               @id @default(autoincrement())
  condominiumId      String            @map("condominium_id")
  residentId         String            @map("resident_id")
  requestKey         String?           @map("request_key")
  sectorId           String?           @map("sector_id")
  assigneeId         String?           @map("assignee_id")
  category           String
  content            String            @db.Text
  status             ComplaintStatus   @default(TRIAGE)
  priority           ComplaintPriority @default(MEDIUM)
  isAnonymous        Boolean           @default(false) @map("is_anonymous")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  resolvedAt         DateTime?         @map("resolved_at")
  resolvedBy         String?           @map("resolved_by")
  responseDueAt      DateTime?         @map("response_due_at")
  resolutionDueAt    DateTime?         @map("resolution_due_at")
  responseAt         DateTime?         @map("response_at")
  pausedUntil        DateTime?         @map("paused_until")
  pauseReason        String?           @map("pause_reason") @db.Text
  escalatedAt        DateTime?         @map("escalated_at")
  escalationTargetId String?           @map("escalation_target_id")
  csatScore          Int?              @map("csat_score")
  csatComment        String?           @map("csat_comment") @db.Text
  csatRespondedAt    DateTime?         @map("csat_responded_at")
  lastNudgedAt       DateTime?         @map("last_nudged_at")
  closedAt           DateTime?         @map("closed_at")

  // Relations
  condominium      Condominium              @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  // Resident deletion is BLOCKED when complaints reference it (Restrict).
  // The service-layer guard in deleteResident() returns a friendly 409 first,
  // but Restrict is a defense-in-depth invariant: no path can silently erase
  // the complaints log by deleting a resident (raw SQL, accidental cascades, etc).
  resident         Resident                 @relation(fields: [residentId], references: [id], onDelete: Restrict)
  sector           Sector?                  @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  assignee         User?                    @relation("ComplaintAssignee", fields: [assigneeId], references: [id])
  escalationTarget User?                    @relation("ComplaintEscalationTarget", fields: [escalationTargetId], references: [id])
  attachments      ComplaintAttachment[]
  statusHistory    ComplaintStatusHistory[]
  assignments      ComplaintAssignment[]
  messages         ComplaintMessage[]

  @@unique([residentId, condominiumId, requestKey])
  @@index([condominiumId, status])
  @@index([condominiumId, status, createdAt])
  @@index([condominiumId, priority])
  @@index([condominiumId, sectorId])
  @@index([assigneeId])
  @@map("complaints")
}

model ComplaintAttachment {
  id          String   @id @default(cuid())
  complaintId Int      @map("complaint_id")
  fileUrl     String   @map("file_url")
  fileName    String   @map("file_name")
  fileType    String   @map("file_type")
  fileSize    Int      @map("file_size")
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  // Relations
  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@map("complaint_attachments")
}

model ComplaintStatusHistory {
  id          String          @id @default(cuid())
  complaintId Int             @map("complaint_id")
  fromStatus  ComplaintStatus @map("from_status")
  toStatus    ComplaintStatus @map("to_status")
  // NOTE: not a FK — accepts the sentinel value "system" for cron/automation
  // transitions. Migrating to a real FK requires (a) introducing a system
  // user row OR (b) splitting into actorUserId? + actorType columns. Tracked
  // in #13 (P0) — kept as plain String for now to avoid breaking the SLA
  // cron and bulk auto-close paths.
  changedBy   String          @map("changed_by")
  notes       String?         @db.Text
  action      String          @default("STATUS_CHANGE")
  metadata    Json?           @db.JsonB
  createdAt   DateTime        @default(now()) @map("created_at")

  // Relations
  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@map("complaint_status_history")
}

model Sector {
  id            String   @id @default(cuid())
  condominiumId String   @map("condominium_id")
  name          String
  categories    String[]
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  condominium          Condominium           @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  members              SectorMember[]
  complaints           Complaint[]
  complaintAssignments ComplaintAssignment[]
  cannedResponses      CannedResponse[]
  permissions          SectorPermission[]
  allowedForwardingIds String[]              @default([]) @map("allowed_forwarding_ids")

  @@unique([condominiumId, name])
  @@index([condominiumId])
  @@map("sectors")
}

model SectorMember {
  id        String   @id @default(cuid())
  sectorId  String   @map("sector_id")
  userId    String   @map("user_id")
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  workload  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  sector              Sector                           @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  user                User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionOverrides SectorMemberPermissionOverride[]

  @@unique([sectorId, userId])
  @@index([sectorId])
  @@map("sector_members")
}

model SectorPermission {
  id        String   @id @default(cuid())
  sectorId  String   @map("sector_id")
  action    String
  createdAt DateTime @default(now()) @map("created_at")

  sector Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@unique([sectorId, action])
  @@index([sectorId])
  @@map("sector_permissions")
}

model SectorMemberPermissionOverride {
  id             String   @id @default(cuid())
  sectorMemberId String   @map("sector_member_id")
  action         String
  granted        Boolean
  createdAt      DateTime @default(now()) @map("created_at")

  sectorMember SectorMember @relation(fields: [sectorMemberId], references: [id], onDelete: Cascade)

  @@unique([sectorMemberId, action])
  @@index([sectorMemberId])
  @@map("sector_member_permission_overrides")
}

model ComplaintAssignment {
  id          String   @id @default(cuid())
  complaintId Int      @map("complaint_id")
  sectorId    String   @map("sector_id")
  assigneeId  String?  @map("assignee_id")
  assignedBy  String?  @map("assigned_by")
  reason      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  complaint      Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  sector         Sector    @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  assignee       User?     @relation("ComplaintAssignmentAssignee", fields: [assigneeId], references: [id])
  assignedByUser User?     @relation("ComplaintAssignmentAssignedBy", fields: [assignedBy], references: [id])

  @@index([complaintId, sectorId])
  @@map("complaint_assignments")
}

model SlaConfig {
  id                      String            @id @default(cuid())
  condominiumId           String?           @map("condominium_id")
  priority                ComplaintPriority
  responseMinutes         Int               @map("response_minutes")
  resolutionMinutes       Int               @map("resolution_minutes")
  escalationBufferMinutes Int               @default(30) @map("escalation_buffer_minutes")
  workingHours            Json?             @db.JsonB
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  condominium Condominium? @relation(fields: [condominiumId], references: [id], onDelete: Cascade)

  @@unique([condominiumId, priority])
  @@index([priority])
  @@map("sla_config")
}

model ResidentDocument {
  id          String         @id @default(cuid())
  residentId  String         @map("resident_id")
  type        String
  number      String?
  status      DocumentStatus @default(PENDING)
  observation String?        @db.Text
  fileUrl     String?        @map("file_url")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  resident Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId, status])
  @@map("resident_documents")
}

model Message {
  id                String         @id @default(cuid())
  condominiumId     String         @map("condominium_id")
  type              MessageType
  scope             MessageScope
  targetTower       String?        @map("target_tower")
  targetFloor       String?        @map("target_floor")
  targetUnit        String?        @map("target_unit")
  content           String         @db.Text
  whatsappMessageId String?        @map("whatsapp_message_id")
  whatsappStatus    WhatsAppStatus @default(SENT) @map("whatsapp_status")
  batchId           String?        @map("batch_id")
  recipientCount    Int            @default(0) @map("recipient_count")
  sentBy            String         @map("sent_by")
  sentAt            DateTime       @default(now()) @map("sent_at")

  // Relations
  condominium Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)

  @@index([condominiumId, sentAt])
  @@map("messages")
}

model AuditLog {
  id        String   @id @default(cuid())
  // NOTE: not a FK by design — audit trails MUST survive user deletion.
  // Adding @relation with onDelete:SetNull is on the roadmap (#13) once a
  // backfill pass scrubs orphaned ids; today some rows reference users
  // that have already been hard-deleted in pre-RLS environments.
  userId    String   @map("user_id")
  action    String
  resource  String
  metadata  Json?
  ipAddress String   @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([resource])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String   @db.Text
  data      Json?    @db.JsonB
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ComplaintMessage {
  id                String   @id @default(cuid())
  complaintId       Int      @map("complaint_id")
  senderId          String   @map("sender_id")
  senderRole        String   @map("sender_role")
  content           String   @db.Text
  attachmentUrl     String?  @map("attachment_url")
  source            String   @default("WEB")
  isInternal        Boolean  @default(false) @map("is_internal")
  whatsappStatus    String?  @map("whatsapp_status")
  whatsappMessageId String?  @map("whatsapp_message_id")
  createdAt         DateTime @default(now()) @map("created_at")

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  sender    User      @relation("ComplaintMessageSender", fields: [senderId], references: [id])

  @@index([complaintId, createdAt])
  @@map("complaint_messages")
}

model CannedResponse {
  id            String   @id @default(cuid())
  condominiumId String?  @map("condominium_id")
  sectorId      String?  @map("sector_id")
  title         String
  content       String   @db.Text
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  condominium Condominium? @relation(fields: [condominiumId], references: [id])
  sector      Sector?      @relation(fields: [sectorId], references: [id])

  @@index([condominiumId])
  @@index([sectorId])
  @@map("canned_responses")
}

// =====================================================
// Billing & Subscriptions
// =====================================================

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELLED
  EXPIRED
}

enum PaymentBillType {
  FIRST_CYCLE
  SUBSCRIPTION_CYCLE
  MANUAL
}

enum PaymentMethod {
  PIX
  CARD
}

enum PaymentBillStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
  FAILED
}

model Plan {
  id                 String   @id @default(cuid())
  slug               String   @unique
  displayName        String   @map("display_name")
  minCondominiums    Int      @map("min_condominiums")
  maxCondominiums    Int      @map("max_condominiums")
  pricePerCondoCents Int      @map("price_per_condo_cents")
  setupFeeCents      Int      @default(200000) @map("setup_fee_cents")
  isActive           Boolean  @default(true) @map("is_active")
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]
  bills         PaymentBill[]

  @@map("plans")
}

model Subscription {
  id                 String             @id @default(cuid())
  syndicId           String             @unique @map("syndic_id")
  currentPlanId      String?            @map("current_plan_id")
  status             SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?          @map("trial_ends_at")
  currentPeriodStart DateTime?          @map("current_period_start")
  currentPeriodEnd   DateTime?          @map("current_period_end")
  cancelledAt        DateTime?          @map("cancelled_at")
  setupPaid          Boolean            @default(false) @map("setup_paid")
  providerId         String             @default("abacatepay") @map("provider_id")
  externalCustomerId String?            @map("external_customer_id")
  metadata           Json?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  syndic      User          @relation("SyndicSubscription", fields: [syndicId], references: [id], onDelete: Cascade)
  currentPlan Plan?         @relation(fields: [currentPlanId], references: [id])
  bills       PaymentBill[]

  @@index([status])
  @@index([currentPeriodEnd])
  @@index([trialEndsAt])
  @@map("subscriptions")
}

model PaymentBill {
  id              String            @id @default(cuid())
  subscriptionId  String            @map("subscription_id")
  planId          String?           @map("plan_id")
  type            PaymentBillType
  method          PaymentMethod?
  status          PaymentBillStatus @default(PENDING)
  amountCents     Int               @map("amount_cents")
  breakdown       Json
  periodStart     DateTime?         @map("period_start")
  periodEnd       DateTime?         @map("period_end")
  providerId      String            @default("abacatepay") @map("provider_id")
  externalId      String?           @map("external_id")
  checkoutUrl     String?           @map("checkout_url")
  pixBrCode       String?           @map("pix_brcode") @db.Text
  pixBrCodeBase64 String?           @map("pix_brcode_base64") @db.Text
  expiresAt       DateTime?         @map("expires_at")
  paidAt          DateTime?         @map("paid_at")
  providerPayload Json?             @map("provider_payload")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  plan         Plan?        @relation(fields: [planId], references: [id])

  @@index([subscriptionId, status])
  @@index([externalId])
  @@map("payment_bills")
}

model WebhookEvent {
  id          String    @id @default(cuid())
  providerId  String    @default("abacatepay") @map("provider_id")
  eventType   String    @map("event_type")
  externalId  String?   @map("external_id")
  payload     Json
  processedAt DateTime? @map("processed_at")
  error       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([providerId, eventType])
  @@index([externalId])
  @@map("webhook_events")
}

enum ActivityType {
  MESSAGE_SENT
  MESSAGE_FAILED
  COMPLAINT_STATUS_CHANGED
  COMPLAINT_CREATED
  RESIDENT_CREATED
  RESIDENT_UPDATED
}

model ActivityLog {
  id            String       @id @default(cuid())
  condominiumId String       @map("condominium_id")
  // NOTE: not a FK by design (#13) — activity logs accept "system" /
  // automation actor values and must survive user deletion. Backfill +
  // schema split (actorUserId? FK + actorType) is the long-term plan.
  userId        String       @map("user_id")
  userName      String?      @map("user_name")
  type          ActivityType
  description   String       @db.Text
  metadata      Json?        @db.JsonB
  targetId      String?      @map("target_id")
  targetType    String?      @map("target_type")
  status        String       @default("success")
  errorMessage  String?      @map("error_message")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([condominiumId, createdAt])
  @@index([type])
  @@index([userId])
  @@map("activity_logs")
}
