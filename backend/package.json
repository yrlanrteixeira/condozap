{
  "name": "@talkzap/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx --env-file=.env prisma/seed.ts",
    "db:clear": "tsx prisma/clear.ts",
    "db:reset": "npm run db:clear && npm run prisma:seed",
    "db:fresh": "prisma migrate reset --force",
    "db:update-consent": "tsx prisma/update-consent.ts",
    "storage:create-buckets": "tsx scripts/create-storage-buckets.ts",
    "storage:test": "tsx scripts/test-storage.ts",
    "billing:test-webhook": "tsx --env-file=.env scripts/test-abacatepay-webhook.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@supabase/supabase-js": "^2.86.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "typescript": "^5.7.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5"
  }
}
