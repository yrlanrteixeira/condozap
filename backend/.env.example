# ==========================================
# TalkZap Backend - Environment Variables
# ==========================================

# --------------------------
# Application
# --------------------------
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# --------------------------
# Database (PostgreSQL) — Prisma 7: URL da Migrate/CLI está em prisma.config.ts (datasource.url)
# --------------------------
# Local:
DATABASE_URL=postgresql://postgres:password@localhost:5432/talkzap
#
# (Opcional) Só necessário se usar pooler tipo PgBouncer com URL diferente — o schema usa só DATABASE_URL.
# DIRECT_URL=postgresql://postgres:password@localhost:5432/talkzap
#
# Railway — serviço da API (NÃO use ${{RAILWAY_PRIVATE_DOMAIN}} montado à mão no API:
# isso aponta para o host errado e o Prisma não alcança o Postgres.)
#
# Reference → serviço Postgres → DATABASE_URL (uma variável basta; remova DIRECT_URL do painel.)
# DATABASE_URL=${{postgres.DATABASE_URL}}
#
# Se a rede privada falhar: DATABASE_URL=${{postgres.DATABASE_PUBLIC_URL}}
#
# Variáveis PGDATA / POSTGRES_* / PG* pertencem ao serviço PostgreSQL, não ao da API.

# --------------------------
# JWT Authentication
# --------------------------
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=7d

# --------------------------
# CORS
# --------------------------
# Frontend URL (comma-separated for multiple origins)
CORS_ORIGIN=https://your-frontend-domain.com

# --------------------------
# WhatsApp API (Official - Meta)
# --------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=talkzap_webhook_secret_2025
# App Secret (Meta dashboard → App Settings → Basic). Used to verify
# x-hub-signature-256 (HMAC-SHA256 of the raw body) on webhook deliveries.
# If empty, all incoming webhook POSTs are silently dropped (returns 200).
WHATSAPP_APP_SECRET=

# --------------------------
# Evolution API (Unofficial - Baileys)
# --------------------------
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=talkzap
WHATSAPP_PROVIDER=evolution

# --------------------------
# File Storage
# --------------------------
# Options: local | s3 | supabase
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# S3 / S3-compatible (Railway Object Storage, AWS, etc.)
AWS_S3_ENDPOINT=
AWS_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Supabase (optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------
# Billing (SaaS payments)
# --------------------------
# Which provider adapter to use. Only "abacatepay" is implemented.
PAYMENT_PROVIDER=abacatepay
# AbacatePay API key (Dev Mode keys start with "abc_dev_", live with "abc_live_").
# Server-only. NEVER expose this to the frontend.
ABACATEPAY_API_KEY=
# Long random hex string used as a path segment in the webhook URL.
# Acts as an extra defense since AbacatePay does not document signature validation.
BILLING_WEBHOOK_SECRET=change_me_long_random_hex
# Where AbacatePay should redirect the user after card checkout.
BILLING_RETURN_URL=http://localhost:5173/assinatura?status=return
BILLING_COMPLETION_URL=http://localhost:5173/assinatura?status=ok
