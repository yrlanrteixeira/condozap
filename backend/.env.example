# Docker Compose Environment Variables

# PostgreSQL
POSTGRES_PASSWORD=talkzap_secret_production

# Prisma: conexão direta para migrações (obrigatório com Supabase).
# Supabase: use "Direct" / porta 5432 (não o pooler 6543), senão migrate deploy trava.
# Local/Docker: pode ser igual ao DATABASE_URL.
DIRECT_URL=

# Backend
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-production
CORS_ORIGIN=https://your-domain.com

# WhatsApp API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=talkzap_webhook_secret_2025

# Storage
STORAGE_TYPE=local
